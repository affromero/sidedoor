{
  "name": "thesidedoor",
  "version": "0.1.0",
  "description": "The private side door to your self hosted apps. Reach a self hosted web app from your own phone and devices, privately (LAN / Tailscale), install it to the home screen, with a guided, consent first reach setup. Not a tunnel, not public by default.",
  "author": "Andres Romero <me@afromero.co> (https://afromero.co)",
  "homepage": "https://github.com/affromero/sidedoor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/affromero/sidedoor.git"
  },
  "bugs": {
    "url": "https://github.com/affromero/sidedoor/issues"
  },
  "keywords": [
    "self-hosted",
    "pwa",
    "qrcode",
    "tailscale",
    "homelab",
    "reach",
    "add-to-home-screen",
    "private",
    "lan",
    "connect"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src/styles.css",
    "src/pwa/sw.js",
    "install",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./pwa": {
      "types": "./dist/pwa/index.d.ts",
      "import": "./dist/pwa/index.js",
      "require": "./dist/pwa/index.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./sw.js": "./src/pwa/sw.js",
    "./install/reach-menu.sh": "./install/reach-menu.sh",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.3.5",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
