{
  "name": "@afromero/sidedoor",
  "version": "0.1.0",
  "description": "The private side door to your self-hosted apps. Reach a self-hosted web app from your own phone and devices, privately (LAN / Tailscale), install it to the home screen, with a guided, consent-first reach setup. Not a tunnel, not public by default.",
  "author": "Andres Romero <me@afromero.co> (https://afromero.co)",
  "homepage": "https://github.com/affromero/sidedoor#readme",
  "repository": { "type": "git", "url": "git+https://github.com/affromero/sidedoor.git" },
  "bugs": { "url": "https://github.com/affromero/sidedoor/issues" },
  "publishConfig": { "access": "public" },
  "keywords": [
    "self-hosted",
    "pwa",
    "qrcode",
    "tailscale",
    "homelab",
    "reach",
    "add-to-home-screen",
    "private",
    "lan",
    "connect"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src/styles.css",
    "src/pwa/sw.js",
    "install",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./pwa": {
      "types": "./dist/pwa/index.d.ts",
      "import": "./dist/pwa/index.js",
      "require": "./dist/pwa/index.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./sw.js": "./src/pwa/sw.js",
    "./install/reach-menu.sh": "./install/reach-menu.sh",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
